# AI Service Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=true

# Model Configuration
MODEL_TYPE=mock          # Options: mock | pytorch | tensorflow | huggingface
MODEL_PATH=./model/weights/action_recognition.pt
HF_MODEL_NAME=microsoft/xclip-base-patch32  # HuggingFace model for action recognition

# Confidence thresholds
FIGHT_THRESHOLD=0.65
FALL_THRESHOLD=0.60
CROWD_THRESHOLD=0.55

# Processing
MAX_FRAMES=32
FRAME_SAMPLE_RATE=8      # Sample 1 frame every N frames
BATCH_SIZE=8

# API Key (optional - for secure communication with Node server)
API_SECRET_KEY=ai_service_secret_key_change_me
